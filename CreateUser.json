      "name": "CreateUser",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"status code is as expected.\", function(){\r",
              "    var expectedStatusCode = pm.iterationData.get(\"expectedStatusCode\");\r",
              "    pm.expect(expectedStatusCode).to.eql(pm.response.code);\r",
              "});\r",
              "\r",
              "pm.test(\"response is as expected.\", function(){\r",
              "    var isMessageExpected = pm.iterationData.get(\"isMessageExpected\");\r",
              "    var validateResponseValues = pm.iterationData.get(\"validateResponseValues\");\r",
              "    var responseData = pm.response.json();\r",
              "\r",
              "pm.environment.set(\"id\",  responseData.id);\r",
              "pm.environment.set(\"name\", responseData.name);\r",
              "pm.environment.set(\"email\", responseData.email);\r",
              "pm.environment.set(\"avatar\", responseData.avatar);\r",
              "pm.environment.set(\"password\", responseData.password);\r",
              "\r",
              "    if (isMessageExpected) {\r",
              "        var message = pm.iterationData.get(\"message\");\r",
              "        pm.expect(message).to.eql(pm.response.json().message);\r",
              "    }\r",
              "\r",
              "    if (validateResponseValues) {\r",
              "        var responseValues = pm.iterationData.get(\"responseValues\");\r",
              "        var keys = Object.keys(responseValues);\r",
              "        keys.forEach(function (item) {\r",
              "            pm.expect(responseValues[item], item + \" is expected to be '\" + responseValues[item] + \"' but got this '\"+(pm.response.json())[item]+\"'\").to.eql((pm.response.json())[item]);\r",
              "        }); \r",
              "    }\r",
              "});\r",
              "\r",
              ""
            ],
