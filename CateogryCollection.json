  "item": [
    {
      "name": "CreateCategory",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var res = pm.response.json();\r",
              "pm.environment.set(\"categoryId\", res.id);\r",
              "console.log(\" Category Created with ID:\", res.id);\r",
              "let GetCategoryName = JSON.parse(pm.request.body.raw).name;\r",
              "let getimage = JSON.parse(pm.request.body.raw).image;\r",
              "console.log(GetCategoryName);\r",
              "pm.test(\"Category Created Successfully\", function () {\r",
              "    pm.expect(res.id).to.not.be.null;\r",
              "    pm.expect(res.name).to.equal(GetCategoryName);\r",
              "    pm.expect(res.image).to.equal(getimage);\r",
              "});\r",
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "var CategoryName = \"Categoryis_\" + Math.random().toString(36).substring(2,8);\r",
              "pm.environment.set(\"CategoryName\", CategoryName);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"name\": \"{{CategoryName}}\",\r\n  \"image\": \"http://placeimg.com/640/480/abstract\"\r\n}\r\n",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{PlatzBaseUrl}}categories/",
          "host": [
            "{{PlatzBaseUrl}}categories"
          ],
          "path": [
            ""
          ]
        }
      },
      "response": []
    },
