          "raw": "{\r\n \"userId\": \"{{id}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{PlatzBaseUrl}}users/:id",
          "host": [
