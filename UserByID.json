  "item": [
    {
      "name": "UserByID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Created user data is correct\", function () {",
              "    var responseData = pm.response.json();",
              "    // Compare GET response with saved values",
              "   ",
              "    pm.expect(responseData.name).to.eql(pm.environment.get(\"name\"));",
              "    pm.expect(responseData.email).to.eql(pm.environment.get(\"email\"));",
              "    pm.expect(responseData.avatar).to.eql(pm.environment.get(\"avatar\"));",
              "});",
              "",
              "pm.test(\"Response status code is 200\", function () {",
              "    pm.expect(pm.response.code).to.eql(200);",
              "});",
              "",
              "",
              "",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "\r",
              "\r",
              "pm.environment.get(\"id\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "method": "GET",
        "header": [],
